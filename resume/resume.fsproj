<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <NoDefaultLaunchSettingsFile>True</NoDefaultLaunchSettingsFile>
    <PublishSingleFile>true</PublishSingleFile>
    <ApplicationIcon>favicon.ico</ApplicationIcon> 
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="resume.fsx" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="xslt\**">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>  
  <ItemGroup>
    <PackageReference Include="Avalonia.Desktop" Version="11.3.*" />
    <PackageReference Include="Avalonia.Themes.Fluent" Version="11.3.*" />
    <PackageReference Include="Avalonia.FuncUI" Version="1.5.2" />
    <PackageReference Include="PuppeteerSharp" Version="24.39.0" />
    <PackageReference Include="Markdig" Version="1.1.1" />
    <PackageReference Include="MessageBox.Avalonia" Version="3.3.1" />    
  </ItemGroup>
</Project>